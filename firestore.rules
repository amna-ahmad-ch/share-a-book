rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* =========================
       HELPERS
    ========================= */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isSignedIn()
        && userDoc().data.isAdmin == true;
    }

    function isNotBlocked() {
      return isSignedIn()
        && userDoc().data.isBlocked != true;
    }

    function isBillingActive() {
      return get(/databases/$(database)/documents/billing/status).data.isActive == true;
    }

    /* =========================
       BILLING (kill switch)
    ========================= */

    match /billing/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /* =========================
       BLOCKED USERS (public block list for browse filtering)
    ========================= */

    match /blockedUsers/{uid} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /* =========================
       USERS
    ========================= */

    match /users/{userId} {

      allow read: if isSignedIn() && (
        request.auth.uid == userId
        || isAdmin()
      );

      allow create: if isOwner(userId) && isBillingActive();

      allow update: if (
        (isOwner(userId)
          && isBillingActive()
          && request.resource.data.diff(resource.data)
               .affectedKeys()
               .hasOnly([
                 'name',
                 'school',
               ])
          && request.resource.data.name is string
          && request.resource.data.name.size() > 0
          && request.resource.data.name.size() <= 100
          && request.resource.data.school is string
          && request.resource.data.school.size() > 0
        )
        ||
        (isAdmin()
          && request.resource.data.diff(resource.data)
               .affectedKeys()
               .hasOnly(['isBlocked'])
        )
        ||
        (isAdmin()
          && request.resource.data.diff(resource.data)
               .affectedKeys()
               .hasOnly(['activeListingCount'])
        )
      );

      allow delete: if isAdmin();
    }

    /* =========================
       LISTINGS
    ========================= */

    match /listings/{listingId} {

      allow read: if isSignedIn();

      allow create: if isNotBlocked()
        && isBillingActive()
        && request.resource.data.postedByUid == request.auth.uid
        && request.resource.data.isActive == true;

      allow update: if isBillingActive()
        && isSignedIn()
        && (
          (resource.data.postedByUid == request.auth.uid && isOwnerListingEdit())
          || isAdmin()
        );

      allow delete: if isBillingActive()
        && isSignedIn()
        && (
          resource.data.postedByUid == request.auth.uid
          || isAdmin()
        );
    }

    function isOwnerListingEdit() {
      let data = request.resource.data;
      let prev = resource.data;

      return data.postedByUid == request.auth.uid
        && data.postedByUid == prev.postedByUid
        && data.postedByPhone == prev.postedByPhone
        && data.isActive == true
        && data.isActive == prev.isActive
        && data.createdAt == prev.createdAt
        && data.diff(prev).affectedKeys().hasOnly([
          'title',
          'grade',
          'category',
          'condition',
          'type',
          'price',
          'imageUrl',
          'imagePath',
          'postedBy',
          'school',
        ])
        && data.title is string
        && data.title.size() > 0
        && data.title.size() <= 200
        && data.grade is string
        && data.category is string
        && data.condition in ['Like New', 'Good', 'Fair']
        && data.type in ['free', 'sell']
        && (data.type == 'free' || data.price is number);
    }

    /* =========================
       SCHOOLS
    ========================= */

    match /schools/{schoolId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    /* =========================
       REPORTS
    ========================= */

    match /reports/{reportId} {

      allow read: if isAdmin();

      allow create: if isSignedIn()
        && isNotBlocked()
        && isBillingActive()
        && isValidReport();

      allow update: if isAdmin()
        && request.resource.data.diff(resource.data)
             .affectedKeys()
             .hasOnly(['status']);

      allow delete: if isAdmin();
    }

    function isValidReport() {
      let data = request.resource.data;

      return isSignedIn()
        && data.status == 'pending'
        && data.reportedByUid == request.auth.uid
        && data.posterUid is string
        && data.posterUid != request.auth.uid
        && data.listingId is string
        && data.listingTitle is string
        && data.listingTitle.size() <= 200
        && data.reportedByName is string
        && data.reportedByName.size() <= 100;
    }

    /* =========================
       SUPPORT MESSAGES
    ========================= */

    function isValidSupportMessage() {
      let data = request.resource.data;

      return data.userId == request.auth.uid
        && data.userName is string
        && data.userPhone is string
        && data.userSchool is string
        && data.topic in ['general', 'missing_school', 'problem', 'other']
        && data.message is string
        && data.message.size() > 0
        && data.message.size() <= 1000
        && data.status == 'open';
    }

    match /supportMessages/{messageId} {
      allow list, read: if isAdmin();
      allow create: if isNotBlocked() && isBillingActive() && isValidSupportMessage();
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data)
             .affectedKeys()
             .hasOnly(['status']);
      allow delete: if isAdmin();
    }

  }
}
